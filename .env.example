DATABASE_URL=postgres://koentji:koentji@localhost:5432/koentjilab
SECRET_KEY=change-me-to-a-random-string-at-least-64-bytes-long-for-security
ADMIN_USERNAME=admin

# Admin password. Two ways, in precedence order:
#
#   1. ADMIN_PASSWORD_HASH — an argon2id PHC string. **Use this in
#      production.** Generate with:
#          make hash-admin-password PASSWORD=yourpassword
#      Paste the printed `$argon2id$...` string here.
#
#   2. ADMIN_PASSWORD — plaintext fallback for local dev / e2e. The
#      server logs a warning at startup when this path is active.
#
# If both are set, ADMIN_PASSWORD_HASH wins and ADMIN_PASSWORD is
# ignored.
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=admin

FREE_TRIAL_KEY=FREE_TRIAL
FREE_TRIAL_SUBSCRIPTION_NAME=free
AUTH_CACHE_TTL_SECONDS=900
WORKERS=4

# Session cookie `Secure` flag. Defaults to `true`. Set to `false` ONLY
# for local HTTP dev — a production deployment serving the dashboard
# over TLS must leave this at the default.
COOKIE_SECURE=false

# Docker Compose overrides
APP_PORT=3000
DB_PORT=5432
DB_IMAGE=postgres:16-alpine
POSTGRES_USER=koentji
POSTGRES_PASSWORD=koentji
POSTGRES_DB=koentjilab
